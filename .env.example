# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="CourseWork Eval"
ENV=development
SECRET_KEY=your-secret-key-here

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/coursework
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/coursework

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=coursework-submissions
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/coursework-jobs
SES_SENDER_EMAIL=noreply@yourdomain.com

# ── AWS Cognito ───────────────────────────────────────────────────────────────
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=your-cognito-client-id
COGNITO_REGION=us-east-1

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=your-github-pat-for-private-repos

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
